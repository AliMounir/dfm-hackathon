# Copy to .env.local and paste the values from Supabase Project Settings > API.

# Safe to expose in the browser. Used by the frontend and server routes.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Never prefix this with NEXT_PUBLIC and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage bucket created by supabase/schema.sql.
SUPABASE_UPLOAD_BUCKET=dfm-data-uploads

# Server-only. Set this in Vercel to the Railway backend URL, without /api.
# Example: https://hazava-backend-production.up.railway.app
BACKEND_API_URL=

# Legacy fallback for older local setups. Prefer BACKEND_API_URL for Railway.
NEXT_PUBLIC_API_URL=
