# Copy to .env and fill in. The backend loads .env at startup.

ENVIRONMENT=development

# CORS — the Next.js frontend origin(s), comma-separated.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Where the M&E project data lives (REDCap/DHIS2/Excel exports, etc.).
# Defaults to the repo-root ./data folder when unset.
# DATA_DIR=../data

# ── LLM (OpenAI) ──────────────────────────────────────────────────────────
# The dashboard composer agent (LangGraph + LangChain) uses OpenAI.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini          # or: gpt-4o for higher-quality reasoning
OPENAI_API_KEY=

# Optional: LangSmith tracing for debugging the agent graph
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
