# Copy to .env and fill in. The backend loads .env at startup.

ENVIRONMENT=development

# CORS — the Next.js frontend origin(s), comma-separated.
CORS_ORIGINS=http://localhost:3000

# Where the M&E project data lives (REDCap/DHIS2/Excel exports, etc.).
# Defaults to the repo-root ./data folder when unset.
# DATA_DIR=../data

# LLM provider for the assistant. Anthropic Claude is the default.
# Only the key matching LLM_PROVIDER is required.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Supabase — used by the upload backend and future processing services.
