# Copy to .env and fill in. The backend loads .env at startup.

ENVIRONMENT=development

# CORS — the Next.js frontend origin(s), comma-separated.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-vercel-app.vercel.app

# Where the M&E project data lives (REDCap/DHIS2/Excel exports, etc.).
# Defaults to the repo-root ./data folder when unset.
# DATA_DIR=../data

# ── LLM (OpenAI) ──────────────────────────────────────────────────────────
# The dashboard composer agent uses OpenAI via LangChain.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini         # cheaper demo default; use a stronger model in Railway if needed
OPENAI_API_KEY=

# Optional: LangSmith tracing for debugging the agent
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=

# ── Supabase (upload backend + project management) ─────────────────────────
SUPABASE_URL=https://ajtlyedkbybqmwyvhgja.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFqdGx5ZWRrYnlicW13eXZoZ2phIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI1OTEwOTcsImV4cCI6MjA5ODE2NzA5N30.F6ePo-OUEzGNzVYF_VkAMQx-hq4CJecno8hCH-31Q7o
# Secret — do NOT commit the real value. Put it in backend/.env (gitignored).
