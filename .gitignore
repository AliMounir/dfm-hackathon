# Monorepo root ignores (frontend/ has its own .gitignore too)

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Python / backend
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Env files
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.pem

# Claude Code local tooling/state
.claude/

# Generated data artifacts (regenerate with backend/scripts/parse_data.py)
data/projects/**/*.md
data/**/_parsed.json
data/DATA_OVERVIEW.md
